# Copy this file to .env and adjust values as needed.
# `docker compose` reads .env automatically; never commit your real .env.

# --- Build-time arguments (forwarded to the Dockerfile) ----------------
# PHP version for the moodlehq/moodle-php-apache base image.
# Moodle 5.2 supports PHP 8.2, 8.3, and 8.4.
PHP_VERSION=8.4

# Moodle branch to clone from https://github.com/moodle/moodle.git
MOODLE_BRANCH=MOODLE_502_STABLE

# --- Runtime configuration ---------------------------------------------
# Hostname the browser uses to reach Moodle. Must match:
#   1) the name passed to `mkcert` (e.g. `mkcert moodle.local`)
#   2) the entry you add to /etc/hosts (e.g. `127.0.0.1 moodle.local`)
#   3) the site block name in docker/caddy/Caddyfile
MOODLE_WEB_HOST=moodle.local

# Protocol used to build $CFG->wwwroot. Must be "http" or "https".
# When using Caddy as a reverse proxy, set to "https".
MOODLE_WEB_PROTOCOL=https

# Set to 1 if Moodle sits behind a reverse proxy (Caddy/Traefik/nginx).
# Enables $CFG->sslproxy so Moodle trusts X-Forwarded-Proto.
MOODLE_BEHIND_PROXY=1

# Host port that maps directly to the moodle container (Apache on 80).
# Useful for debugging; the canonical entry point is Caddy on 443.
MOODLE_HTTP_PORT=8000

# HTTPS port that Caddy advertises. Leave at 443 unless you proxy
# through something else on the host.
MOODLE_HTTPS_PORT=443

# MariaDB credentials. MUST match the values used by the db service.
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=change-me-in-production
