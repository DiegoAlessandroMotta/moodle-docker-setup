# Copy this file to .env for local development.
# `docker compose -f docker-compose.yml -f docker-compose.dev.yml`
# reads .env automatically.
#
# For production (Dokploy), mirror the variable names in the
# Dokploy project's "Environment" tab — there's no .env there.
# Anything prod-specific (DOKPLOY_NETWORK, real domain, managed
# DB credentials) is set in the UI, not in this file.

# --- Build-time arguments (forwarded to the Dockerfile) ----------------
# PHP version for the moodlehq/moodle-php-apache base image.
# Moodle 5.2 supports PHP 8.2, 8.3, and 8.4.
PHP_VERSION=8.4

# Moodle release tarball. Pattern:
#   https://packaging.moodle.org/stableXYZ/moodle-latest-XYZ.tgz
# where XYZ is the version without the dot (502 for 5.2, 45 for 4.5).
MOODLE_TARBALL_URL=https://packaging.moodle.org/stable502/moodle-latest-502.tgz

# Image tag baked into the built image (helps distinguish prod vs dev
# images when you push to a registry later).
MOODLE_IMAGE_TAG=5.2

# --- Public hostname ---------------------------------------------------
# Dev:     moodle.local (must match your /etc/hosts and the Caddyfile)
# Prod:    moodle.example.com (set this in the Dokploy UI)
MOODLE_WEB_HOST=moodle.local

# --- TLS / reverse proxy ----------------------------------------------
# Both dev (Caddy) and prod (Traefik in Dokploy) terminate TLS in front
# of the container, so the same settings work in both.
MOODLE_WEB_PROTOCOL=https
MOODLE_BEHIND_PROXY=1
MOODLE_HTTPS_PORT=443

# --- Database ---------------------------------------------------------
# Dev:     the in-stack MariaDB service (host "db" inside compose).
# Prod:    the Dokploy-managed database (host set in the Dokploy UI).
MOODLE_DB_TYPE=mariadb
MOODLE_DB_HOST=db
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=change-me-in-production
MOODLE_DB_COLLATION=utf8mb4_bin

# --- Debug ------------------------------------------------------------
# Dev:  1  (verbose output, relaxed password policy)
# Prod: 0  (silent, strict policy)
MOODLE_DEBUG=1

# --- Dev-only --------------------------------------------------------
# Direct host port to the moodle container for debugging. Ignored in prod.
MOODLE_HTTP_PORT=8000

# --- Prod-only -------------------------------------------------------
# Traefik labels reference this. Dokploy creates one called
# "dokploy-network" by default; change only if your install differs.
# DOKPLOY_NETWORK=dokploy-network

# --- AI provider (used by local_aiquiz_gen and any other plugin that
#     uses Moodle's core_ai framework) -------------------------------
# The plugin does not read these directly. To configure the provider
# from these env vars in one shot, run the bundled seed script after
# the container is up:
#     docker compose exec moodle php /var/www/html/local/aiquiz_gen/bin/seed_provider.php
# Or configure manually in Site administration → AI → Providers.
#
# MOODLE_AI_PROVIDER=gemini
# MOODLE_AI_GEMINI_APIKEY=
# MOODLE_AI_GEMINI_MODEL=gemini-2.5-flash
# MOODLE_AI_OPENAI_APIKEY=
# MOODLE_AI_OLLAMA_BASEURL=http://host.docker.internal:11434
