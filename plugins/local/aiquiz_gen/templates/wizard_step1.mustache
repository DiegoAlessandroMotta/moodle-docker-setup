{{!
    @template    local_aiquiz_gen/wizard_step1
    @copyright   2025 Your Organization
    @license     http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Wizard step 1: Content source selection.

    Context variables required for this template:
    * step1_title - Step heading text
    * step1_description - Step subtitle text
    * form_url - Form action URL
    * sesskey - Session key
    * courseid - Course ID
    * select_content_sources - Label text
    * select_content_sources_help - Help text
    * group1_title - "Add Your Own Content" heading (HTML)
    * group2_title - "Use Course Content" heading (HTML)
    * source_manual / source_manual_desc - Manual entry labels
    * source_upload / source_upload_desc - File upload labels
    * source_url / source_url_desc - URL extraction labels
    * source_activities / source_activities_desc - Activities labels
    * wizard_recommended - Recommended badge text
    * source_scan_course / source_scan_course_desc - Scan course labels
    * source_scan_resources / source_scan_resources_desc - Scan resources labels
    * source_scan_activities / source_scan_activities_desc - Scan activities labels
    * selected_sources - "Selected sources" label
    * manual_text_entry / manual_text_entry_help / manual_text_placeholder - Manual textarea
    * upload_files / upload_files_help / choose_files / no_files_selected - File upload section
    * supported_formats - Supported formats text
    * php_limits - PHP upload limits text (HTML)
    * url_label / url_help / url_placeholder / url_per_line_help - URL section
    * select_activities / select_activities_help - Activity selector heading
    * has_activities - Whether activities exist
    * activities_count_text - "N activities available" text
    * select_all - Select all button text
    * deselect_all - Deselect all button text
    * activities - Array of activity objects with: id, name, type, emoji_html
    * n_activities_selected - "0 activities selected" text
    * noactivities - No activities message
    * cancel_url - Cancel button URL
    * cancel - Cancel button text
    * next - Next button text

    Example context (json):
    {
        "form_url": "#",
        "has_activities": true,
        "activities": [{"id": 1, "name": "Lesson 1", "type": "Page", "emoji_html": "<i class=\"fa fa-file\"></i>"}]
    }
}}
<div class="aiquiz-step-content">
    <h2 class="title is-4 mb-0">{{{step1_title}}}</h2>
    <p class="subtitle is-6 has-text-grey mt-1 mb-4">{{{step1_description}}}</p>
    <hr class="mt-0 mb-5">

    <form method="post" action="{{form_url}}" id="content-upload-form" enctype="multipart/form-data">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="action" value="upload_content">
        <input type="hidden" name="courseid" value="{{courseid}}">

        {{! Content source selection }}
        <div class="field mb-5">
            <label class="label is-medium">{{{select_content_sources}}}</label>
            <p class="help mb-4">{{{select_content_sources_help}}}</p>

            {{! GROUP 1: Add Your Own Content }}
            <div class="aiquiz-source-group mb-5">
                <h5 class="aiquiz-source-group-title"><i class="fa fa-pencil aiquiz-icon-warning"></i> {{{group1_title}}}</h5>
                <div class="columns is-multiline">
                    {{! Option 1: Manual Text Entry }}
                    <div class="column is-4">
                        <label class="aiquiz-source-card" for="source_manual">
                            <input type="checkbox" name="content_sources[]" value="manual" id="source_manual" class="content-source-checkbox aiquiz-source-check" data-source="manual">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-pencil aiquiz-icon-warning"></i></span>
                                <strong class="aiquiz-source-title">{{{source_manual}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_manual_desc}}}</span>
                            </span>
                        </label>
                    </div>

                    {{! Option 2: File Upload }}
                    <div class="column is-4">
                        <label class="aiquiz-source-card" for="source_upload">
                            <input type="checkbox" name="content_sources[]" value="upload" id="source_upload" class="content-source-checkbox aiquiz-source-check" data-source="upload">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-folder-open aiquiz-icon-purple"></i></span>
                                <strong class="aiquiz-source-title">{{{source_upload}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_upload_desc}}}</span>
                            </span>
                        </label>
                    </div>

                    {{! Option 3: URL Extraction }}
                    <div class="column is-4">
                        <label class="aiquiz-source-card" for="source_url">
                            <input type="checkbox" name="content_sources[]" value="url" id="source_url" class="content-source-checkbox aiquiz-source-check" data-source="url">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-globe aiquiz-icon-info"></i></span>
                                <strong class="aiquiz-source-title">{{{source_url_title}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_url_desc}}}</span>
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            {{! GROUP 2: Use Course Content }}
            <div class="aiquiz-source-group">
                <h5 class="aiquiz-source-group-title"><i class="fa fa-book aiquiz-icon-success"></i> {{{group2_title}}}</h5>
                <div class="columns is-multiline">
                    {{! Option 4: Course Activities }}
                    <div class="column is-6">
                        <label class="aiquiz-source-card aiquiz-source-featured" for="source_activities">
                            <input type="checkbox" name="content_sources[]" value="activities" id="source_activities" class="content-source-checkbox aiquiz-source-check" data-source="activities">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon aiquiz-icon-lg"><i class="fa fa-book aiquiz-icon-primary"></i></span>
                                <span class="aiquiz-source-text">
                                    <strong class="aiquiz-source-title">{{{source_activities}}}</strong>
                                    <span class="aiquiz-source-desc">{{{source_activities_desc}}}</span>
                                    <span class="aiquiz-source-badge"><i class="fa fa-star aiquiz-icon-warning"></i> {{{wizard_recommended}}}</span>
                                </span>
                            </span>
                        </label>
                    </div>

                    {{! Option 5: Scan Entire Course }}
                    <div class="column is-6">
                        <label class="aiquiz-source-card" for="source_scan_course">
                            <input type="checkbox" name="content_sources[]" value="scan_course" id="source_scan_course" class="content-source-checkbox aiquiz-source-check" data-source="scan_course">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-graduation-cap aiquiz-icon-success"></i></span>
                                <strong class="aiquiz-source-title">{{{source_scan_course}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_scan_course_desc}}}</span>
                            </span>
                        </label>
                    </div>

                    {{! Option 6: Scan All Resources }}
                    <div class="column is-6">
                        <label class="aiquiz-source-card" for="source_scan_resources">
                            <input type="checkbox" name="content_sources[]" value="scan_resources" id="source_scan_resources" class="content-source-checkbox aiquiz-source-check" data-source="scan_resources">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-book aiquiz-icon-purple"></i></span>
                                <strong class="aiquiz-source-title">{{{source_scan_resources}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_scan_resources_desc}}}</span>
                            </span>
                        </label>
                    </div>

                    {{! Option 7: Scan All Activities }}
                    <div class="column is-6">
                        <label class="aiquiz-source-card" for="source_scan_activities">
                            <input type="checkbox" name="content_sources[]" value="scan_activities" id="source_scan_activities" class="content-source-checkbox aiquiz-source-check" data-source="scan_activities">
                            <span class="aiquiz-source-content">
                                <span class="aiquiz-source-icon"><i class="fa fa-edit aiquiz-icon-danger"></i></span>
                                <strong class="aiquiz-source-title">{{{source_scan_activities}}}</strong>
                                <span class="aiquiz-source-desc">{{{source_scan_activities_desc}}}</span>
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            {{! Warning banner for bulk scan options — shown/hidden by JS }}
            <div id="aiquiz-scan-warning" class="notification is-warning is-light mt-3" style="display:none;">
                <i class="fa fa-exclamation-triangle"></i>
                <span id="aiquiz-scan-warning-text"></span>
            </div>

            {{! Selected sources display }}
            <div class="notification is-info is-light mt-4 aiquiz-hidden" id="selected-sources-display">
                <strong>{{{selected_sources}}}: </strong>
                <span id="selected-sources-list" class="tag is-primary is-medium ml-2"></span>
            </div>
        </div>

        {{! Bulk scan hidden sections }}
        <div class="aiquiz-hidden" id="section-scan_course"></div>
        <div class="aiquiz-hidden" id="section-scan_resources"></div>
        <div class="aiquiz-hidden" id="section-scan_activities"></div>

        {{! Manual text entry section }}
        <div class="field mb-5 aiquiz-hidden" id="section-manual">
            <label class="label"><i class="fa fa-pencil aiquiz-icon-warning"></i> {{{manual_text_entry}}}</label>
            <p class="help mb-3">{{{manual_text_entry_help}}}</p>
            <div class="control">
                <textarea name="manual_text" id="manual_text" rows="8" class="textarea" placeholder="{{manual_text_placeholder}}"></textarea>
            </div>
        </div>

        {{! File upload section }}
        <div class="field mb-5 aiquiz-hidden" id="section-upload">
            <label class="label"><i class="fa fa-folder-open aiquiz-icon-purple"></i> {{{upload_files}}}</label>
            <p class="help mb-3">{{{upload_files_help}}}</p>
            <div class="aiquiz-dropzone" id="aiquiz-dropzone">
                <input type="file" name="contentfiles[]" id="content-files" class="aiquiz-dropzone-input" multiple="multiple" accept=".pdf,.doc,.docx,.ppt,.pptx,.txt">
                <div class="aiquiz-dropzone-body">
                    <span class="aiquiz-dropzone-icon">&#x1F4C2;</span>
                    <p class="aiquiz-dropzone-primary">{{{choose_files}}}</p>
                    <p class="aiquiz-dropzone-hint">or drag &amp; drop files here</p>
                    <p class="aiquiz-dropzone-files" id="aiquiz-dropzone-label">{{{no_files_selected}}}</p>
                </div>
            </div>
            <p class="help mt-2">{{{supported_formats}}}</p>
            <div class="mt-2"><small class="has-text-grey is-size-7">{{{php_limits}}}</small></div>
            <div class="mt-2" id="uploaded-files-list"></div>
        </div>

        {{! URL extraction section }}
        <div class="field mb-5 aiquiz-hidden" id="section-url">
            <label class="label"><i class="fa fa-globe aiquiz-icon-info"></i> {{{url_label}}}</label>
            <p class="help mb-3">{{{url_help}}}</p>
            <div class="control">
                <textarea name="url_list" id="url_list" rows="4" class="textarea" placeholder="{{url_placeholder}}"></textarea>
            </div>
            <p class="help mt-2">{{{url_per_line_help}}}</p>
        </div>

        {{! Activity selection section }}
        <div class="aiquiz-activities-section aiquiz-hidden" id="section-activities">
            <div class="aiquiz-activities-header">
                <span class="aiquiz-activities-icon"><i class="fa fa-book aiquiz-icon-info"></i></span>
                <div class="aiquiz-activities-header-text">
                    <h3 class="aiquiz-activities-title">{{{select_activities}}}</h3>
                    <p class="aiquiz-activities-subtitle">{{{select_activities_help}}}</p>
                </div>
            </div>

            {{#has_activities}}
            <div class="aiquiz-activities-actions">
                <div class="aiquiz-activities-buttons">
                    <button type="button" id="select-all-activities" class="aiquiz-action-btn aiquiz-action-select">
                        <i class="fa fa-check"></i> {{{select_all}}}
                    </button>
                    <button type="button" id="deselect-all-activities" class="aiquiz-action-btn aiquiz-action-deselect">
                        <i class="fa fa-times"></i> {{{deselect_all}}}
                    </button>
                </div>
                <span class="aiquiz-activities-count">{{{activities_count_text}}}</span>
            </div>

            <div class="aiquiz-activities-list">
                {{#activities}}
                <label class="aiquiz-activity-card">
                    <input type="checkbox" name="activityids[]" value="{{id}}" class="aiquiz-activity-checkbox" data-modtype="{{modname}}">
                    <span class="aiquiz-activity-checkmark"></span>
                    <span class="aiquiz-activity-content">
                        <span class="aiquiz-activity-emoji">{{{emoji_html}}}</span>
                        <span class="aiquiz-activity-text">
                            <span class="aiquiz-activity-name">{{{name}}}</span>
                            <span class="aiquiz-activity-type">{{{type}}}</span>
                        </span>
                    </span>
                </label>
                {{/activities}}
            </div>

            <div class="aiquiz-activities-selected-bar">
                <span class="aiquiz-selected-icon"><i class="fa fa-check-circle"></i></span>
                <span id="selected-activities-count" class="aiquiz-selected-text">{{{n_activities_selected}}}</span>
            </div>

            {{! Warning banner for too many activities — shown/hidden by JS }}
            <div id="aiquiz-activity-warning" class="notification is-warning is-light mt-3" style="display:none;">
                <i class="fa fa-exclamation-triangle"></i>
                <span id="aiquiz-activity-warning-text"></span>
            </div>
            {{/has_activities}}

            {{^has_activities}}
            <div class="notification is-info is-light">{{{noactivities}}}</div>
            {{/has_activities}}
        </div>

        {{! Navigation buttons }}
        <div class="level is-mobile mt-6 pt-4 aiquiz-border-top">
            <div class="level-left">
                <a href="{{cancel_url}}" class="button is-light">{{{cancel}}}</a>
            </div>
            <div class="level-right">
                <button type="submit" class="button is-primary" id="step1-next">
                    {{{next}}} <i class="fa fa-arrow-right"></i>
                </button>
            </div>
        </div>
    </form>
</div>
