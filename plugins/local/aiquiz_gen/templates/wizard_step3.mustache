{{!
    @template    local_aiquiz_gen/wizard_step3
    @copyright   2025 Your Organization
    @license     http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Wizard step 3: Question parameters and configuration.

    Context variables required for this template:
    * step3_title - Step heading
    * step3_description - Step subtitle
    * no_topics - Whether no topics are selected (show warning)
    * no_topics_message - Warning message when no topics selected
    * back_to_step2_url - URL to go back to step 2
    * back_to_step2 - Back button text
    * topics_info_html - Pre-built topics info bar HTML
    * form_url - Form action URL
    * sesskey - Session key
    * total_questions_label - Label for total questions input
    * question_difficulty_label - Difficulty label
    * difficulty_options - Array of difficulty options: value, label, css_class, is_checked
    * question_types_label - Question types heading
    * qtype_count_hint - Hint text for question type counts
    * question_types - Array of question type objects: type, label, icon_html, color, icon_style
    * total_label - "Total" label
    * blooms_taxonomy_label - Bloom's taxonomy heading
    * blooms_hint - Bloom's taxonomy hint text
    * blooms_levels - Array: level, label, default_val, color, desc, dot_style, slider_style, value_style
    * prev_url - Previous step URL
    * previous - Previous button text
    * generate_questions - Generate button text
    * generating_title - Generating overlay title
    * generating_subtitle - Overlay subtitle
    * generating_warning - Overlay warning text

    Example context (json):
    {
        "no_topics": false,
        "form_url": "/local/aiquiz_gen/wizard.php?...",
        "question_types": [{"type": "multichoice", "label": "Multiple Choice", "icon_html": "<i class=\"fa fa-dot-circle-o\"></i>", "color": "#3B82F6"}]
    }
}}
{{#no_topics}}
<div class="aiquiz-step-content aiquiz-step3-minimal">
    <h2 class="title is-4 mb-0 aiquiz-step3-title">{{{step3_title}}}</h2>
    <p class="subtitle is-6 has-text-grey mt-1 mb-4 aiquiz-step3-subtitle">{{{step3_description}}}</p>
    <hr class="mt-0 mb-5 aiquiz-step3-divider">
    <div class="notification is-warning">{{{no_topics_message}}}</div>
    <a href="{{back_to_step2_url}}" class="button is-primary mt-4">
        <i class="fa fa-arrow-left aiquiz-icon-info"></i> {{{back_to_step2}}}
    </a>
</div>
{{/no_topics}}

{{^no_topics}}
<div class="aiquiz-step-content aiquiz-step3-minimal">
    <h2 class="title is-4 mb-0 aiquiz-step3-title">{{{step3_title}}}</h2>
    <p class="subtitle is-6 has-text-grey mt-1 mb-4 aiquiz-step3-subtitle">{{{step3_description}}}</p>
    <hr class="mt-0 mb-5 aiquiz-step3-divider">

    {{! Topics info bar }}
    {{{topics_info_html}}}

    <form method="post" action="{{form_url}}" id="question-config-form">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="aiquiz-config-grid">
            {{! Total questions card }}
            <div class="aiquiz-config-card">
                <label class="aiquiz-config-label" for="total-questions">{{{total_questions_label}}}</label>
                <input type="number" name="total_questions" id="total-questions" class="aiquiz-config-input"
                       min="1" max="100" value="10" required="required">
            </div>

            {{! Difficulty card }}
            <div class="aiquiz-config-card">
                <label class="aiquiz-config-label">{{{question_difficulty_label}}}</label>
                <div class="aiquiz-diff-buttons">
                    {{#difficulty_options}}
                    <label class="aiquiz-diff-btn {{css_class}}{{#is_checked}} is-active{{/is_checked}}">
                        <input type="radio" name="difficulty" value="{{value}}"{{#is_checked}} checked="checked"{{/is_checked}}>
                        <span>{{{label}}}</span>
                    </label>
                    {{/difficulty_options}}
                </div>
            </div>
        </div>

        {{! Question types section }}
        <div class="aiquiz-section aiquiz-section-qtypes mt-5">
            <div class="aiquiz-section-header">
                <span class="aiquiz-section-icon"><i class="fa fa-edit aiquiz-icon-primary"></i></span>
                <div class="aiquiz-section-title-wrap">
                    <h4 class="aiquiz-section-label">{{{question_types_label}}}</h4>
                    <p class="aiquiz-section-hint">{{{qtype_count_hint}}}</p>
                </div>
            </div>

            <div class="aiquiz-qtype-list">
                {{#question_types}}
                <div class="aiquiz-qtype-row" data-type="{{type}}">
                    <div class="aiquiz-qtype-left aiquiz-flex-center">
                        <span class="aiquiz-qtype-icon aiquiz-flex-center-all" style="{{{icon_style}}}">{{{icon_html}}}</span>
                        <span class="aiquiz-qtype-name aiquiz-flex-center">{{{label}}}</span>
                    </div>
                    <input type="number" name="qtype_count[{{type}}]" id="qtype_count_{{type}}"
                           class="aiquiz-qtype-input" min="0" max="100" value="0">
                </div>
                {{/question_types}}
                <div class="aiquiz-qtype-row aiquiz-qtype-total">
                    <span class="aiquiz-qtype-name">{{{total_label}}}</span>
                    <span id="qtype-total-display" class="aiquiz-qtype-total-val">0 / 10</span>
                </div>
            </div>
        </div>

        {{! Bloom's Taxonomy section }}
        <div class="aiquiz-section aiquiz-section-blooms mt-5">
            <div class="aiquiz-section-header">
                <span class="aiquiz-section-icon"><i class="fa fa-lightbulb-o aiquiz-icon-primary"></i></span>
                <div class="aiquiz-section-title-wrap">
                    <h4 class="aiquiz-section-label">{{{blooms_taxonomy_label}}}</h4>
                    <p class="aiquiz-section-hint">{{{blooms_hint}}}</p>
                </div>
            </div>

            <div class="aiquiz-blooms-list">
                {{#blooms_levels}}
                <div class="aiquiz-blooms-item" data-level="{{level}}">
                    <div class="aiquiz-blooms-label-wrap aiquiz-flex-center">
                        <span class="aiquiz-blooms-dot aiquiz-flex-center" style="{{{dot_style}}}"></span>
                        <span class="aiquiz-blooms-name aiquiz-flex-center">{{{label}}}</span>
                    </div>
                    <div class="aiquiz-blooms-control">
                        <input type="range" name="blooms_{{level}}" id="blooms_{{level}}"
                               min="0" max="100" value="{{default_val}}" class="aiquiz-slider"
                               data-color="{{color}}" style="{{{slider_style}}}">
                        <span id="blooms_{{level}}_value" class="aiquiz-slider-val" style="{{{value_style}}}">{{default_val}}%</span>
                    </div>
                </div>
                {{/blooms_levels}}
                <div class="aiquiz-blooms-item aiquiz-blooms-total-row">
                    <span class="aiquiz-blooms-name">{{{total_label}}}</span>
                    <span id="blooms_total" class="aiquiz-blooms-total-val">100%</span>
                </div>
            </div>
        </div>

        {{! Quiz language section }}
        <div class="aiquiz-section aiquiz-section-language mt-5">
            <div class="aiquiz-section-header">
                <span class="aiquiz-section-icon"><i class="fa fa-globe aiquiz-icon-primary"></i></span>
                <div class="aiquiz-section-title-wrap">
                    <h4 class="aiquiz-section-label">{{{wizard_quiz_language}}}</h4>
                    <p class="aiquiz-section-hint">{{{wizard_language_hint}}}</p>
                </div>
            </div>
            <div class="aiquiz-config-card aiquiz-language-card">
                <select name="language" id="quiz-language" class="aiquiz-config-input aiquiz-language-select">
                    {{#language_options}}
                    <option value="{{value}}"{{#is_selected}} selected="selected"{{/is_selected}}>{{{label}}}</option>
                    {{/language_options}}
                </select>
            </div>
        </div>

        {{! Navigation }}
        <div class="level is-mobile mt-5">
            <div class="level-left">
                <a href="{{prev_url}}" class="button is-light">
                    <i class="fa fa-arrow-left aiquiz-icon-info"></i> {{{previous}}}
                </a>
            </div>
            <div class="level-right">
                <button type="submit" class="button is-primary" id="generate-btn">
                    <i class="fa fa-rocket aiquiz-icon-white"></i> {{{generate_questions}}}
                </button>
            </div>
        </div>
    </form>

    {{! Loading overlay }}
    <div class="aiquiz-generating-overlay aiquiz-hidden" id="loading-overlay">
        <div class="aiquiz-generating-modal">
            <div class="loader"></div>
            <h3 class="generating-title"><i class="fa fa-lightbulb-o aiquiz-icon-primary"></i> {{{generating_title}}}</h3>
            <p class="generating-subtitle">{{{generating_subtitle}}}</p>
            <p class="generating-warning">{{{generating_warning}}}</p>
        </div>
    </div>
</div>
{{/no_topics}}
